---
import '../styles/global.css';

interface Props {
  title: string;
}
const { title } = Astro.props;
const admin = Astro.locals.admin;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title} | PFS Admin</title>
    <script is:inline>
      (function () {
        try {
          var saved = localStorage.getItem('pfs_theme');
          var theme = saved || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
          document.documentElement.setAttribute('data-theme', theme);
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <header class="portal-nav">
      <div class="container nav-inner">
        <a href="/admin/" class="brand">Prosperity Federal Solutions <span>Admin</span></a>
        {admin && (
          <nav class="nav-links">
            <a href="/admin/">Dashboard</a>
            <a href="/admin/clients/">Clients</a>
            <a href="/admin/contracts/">Contracts</a>
            <a href="/admin/tickets/">Tickets</a>
            <a href="/admin/messages/">Messages</a>
            <button id="theme-toggle" class="btn btn-outline btn-sm" type="button" aria-label="Toggle dark mode">🌓</button>
            <a href="/admin/logout" class="btn btn-outline btn-sm">Log Out</a>
          </nav>
        )}
      </div>
    </header>
    <main class="container portal-main">
      <slot />
    </main>
    <script>
      const toggle = document.getElementById('theme-toggle');
      toggle?.addEventListener('click', () => {
        const root = document.documentElement;
        const next = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
        root.setAttribute('data-theme', next);
        try { localStorage.setItem('pfs_theme', next); } catch (e) {}
      });
    </script>
  </body>
</html>

<style>
  .portal-nav { background: var(--color-dark); border-bottom: 1px solid rgba(255,255,255,0.1); }
  .nav-inner { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; padding: 0.9rem 0; gap: 1rem; }
  .brand { color: #fff; font-family: var(--font-heading); font-weight: 700; text-decoration: none; font-size: 1.1rem; }
  .brand span { display: block; font-family: var(--font-body); font-size: 0.7rem; color: var(--color-gold); font-weight: 400; letter-spacing: 0.05em; }
  .nav-links { display: flex; align-items: center; gap: 1.1rem; flex-wrap: wrap; }
  .nav-links a:not(.btn) { color: #e2d4f0; text-decoration: none; font-weight: 600; font-size: 0.9rem; }
  .nav-links a:not(.btn):hover { color: var(--color-teal); }
  .portal-main { padding: 2.5rem 1.5rem; min-height: 60vh; }
</style>
