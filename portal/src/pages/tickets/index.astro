---
import PortalLayout from '../../layouts/PortalLayout.astro';

const client = Astro.locals.client;
if (!client) return Astro.redirect('/login');

const db = Astro.locals.runtime.env.DB;
const tickets = await db
  .prepare('SELECT id, subject, priority, status, created_at FROM tickets WHERE client_id = ? ORDER BY created_at DESC')
  .bind(client.id)
  .all<{ id: string; subject: string; priority: string; status: string; created_at: string }>();
const unread = await db.prepare("SELECT COUNT(*) as c FROM messages WHERE client_id = ? AND author_type = 'admin' AND read_by_client = 0").bind(client.id).first<{ c: number }>();
const created = Astro.url.searchParams.get('created');
---
<PortalLayout title="Support Tickets" unreadCount={unread?.c ?? 0}>
  <h1>Support Tickets</h1>
  <p class="lede">Submit a support request and track responses from our team.</p>
  {created && <p class="form-success">Ticket submitted — we'll respond soon.</p>}

  <div class="card new-ticket">
    <h2>New Ticket</h2>
    <form method="POST" action="/api/tickets/create">
      <div class="form-row">
        <label for="subject">Subject</label>
        <input type="text" id="subject" name="subject" required />
      </div>
      <div class="form-row">
        <label for="priority">Priority</label>
        <select id="priority" name="priority" required>
          <option>Low</option>
          <option selected>Medium</option>
          <option>High</option>
        </select>
      </div>
      <div class="form-row">
        <label for="description">Description</label>
        <textarea id="description" name="description" rows="4" required></textarea>
      </div>
      <button type="submit" class="btn btn-primary">Submit Ticket</button>
    </form>
  </div>

  <div class="card">
    <h2>Your Tickets</h2>
    {tickets.results.length === 0 ? (
      <p class="muted">No tickets yet.</p>
    ) : (
      <table>
        <thead><tr><th>Subject</th><th>Priority</th><th>Status</th><th>Opened</th><th></th></tr></thead>
        <tbody>
          {tickets.results.map((t) => (
            <tr>
              <td>{t.subject}</td>
              <td><span class={`badge badge-${t.priority.toLowerCase()}`}>{t.priority}</span></td>
              <td><span class={`badge badge-${t.status.toLowerCase().replace(' ', '-').replace('in-progress', 'progress')}`}>{t.status}</span></td>
              <td>{t.created_at}</td>
              <td><a href={`/tickets/${t.id}/`} class="btn btn-outline btn-sm">View</a></td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </div>
</PortalLayout>

<style>
  .lede { color: var(--color-text-muted); margin-bottom: 1.5rem; }
  .new-ticket { margin-bottom: 1.5rem; }
  .muted { color: var(--color-text-muted); }
</style>
