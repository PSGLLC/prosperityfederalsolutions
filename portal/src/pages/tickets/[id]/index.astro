---
import PortalLayout from '../../../layouts/PortalLayout.astro';

const client = Astro.locals.client;
if (!client) return Astro.redirect('/login');

const db = Astro.locals.runtime.env.DB;
const id = Astro.params.id;

const ticket = await db
  .prepare('SELECT id, subject, description, priority, status, created_at FROM tickets WHERE id = ? AND client_id = ?')
  .bind(id, client.id)
  .first<{ id: string; subject: string; description: string; priority: string; status: string; created_at: string }>();

if (!ticket) return new Response('Not found', { status: 404 });

const replies = await db
  .prepare('SELECT author_type, body, created_at FROM ticket_replies WHERE ticket_id = ? ORDER BY created_at ASC')
  .bind(id)
  .all<{ author_type: string; body: string; created_at: string }>();
const unread = await db.prepare("SELECT COUNT(*) as c FROM messages WHERE client_id = ? AND author_type = 'admin' AND read_by_client = 0").bind(client.id).first<{ c: number }>();
---
<PortalLayout title={ticket.subject} unreadCount={unread?.c ?? 0}>
  <a href="/tickets/" class="back-link">&larr; All Tickets</a>
  <div class="card">
    <div class="ticket-head">
      <h1>{ticket.subject}</h1>
      <div>
        <span class={`badge badge-${ticket.priority.toLowerCase()}`}>{ticket.priority}</span>
        <span class={`badge badge-${ticket.status.toLowerCase().replace(' ', '-').replace('in-progress','progress')}`}>{ticket.status}</span>
      </div>
    </div>
    <p class="muted">Opened {ticket.created_at}</p>
    <p>{ticket.description}</p>
  </div>

  <div class="card thread">
    <h2>Conversation</h2>
    {replies.results.length === 0 ? (
      <p class="muted">No replies yet.</p>
    ) : (
      <div class="reply-list">
        {replies.results.map((r) => (
          <div class:list={['reply', r.author_type === 'admin' ? 'reply-admin' : 'reply-client']}>
            <p class="reply-meta">{r.author_type === 'admin' ? 'Prosperity Federal Solutions' : 'You'} — {r.created_at}</p>
            <p>{r.body}</p>
          </div>
        ))}
      </div>
    )}
    <form method="POST" action={`/api/tickets/${ticket.id}/reply`} class="reply-form">
      <div class="form-row">
        <label for="body">Add a reply</label>
        <textarea id="body" name="body" rows="3" required></textarea>
      </div>
      <button type="submit" class="btn btn-primary">Send Reply</button>
    </form>
  </div>
</PortalLayout>

<style>
  .back-link { display: inline-block; margin-bottom: 1rem; font-weight: 600; font-size: 0.9rem; text-decoration: none; }
  .ticket-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; flex-wrap: wrap; }
  .muted { color: var(--color-text-muted); font-size: 0.85rem; }
  .thread { margin-top: 1.5rem; }
  .reply-list { display: flex; flex-direction: column; gap: 0.9rem; margin-bottom: 1.25rem; }
  .reply { padding: 0.85rem 1rem; border-radius: 10px; background: var(--color-bg-alt); }
  .reply-admin { border-left: 3px solid var(--color-purple); }
  .reply-client { border-left: 3px solid var(--color-teal); }
  .reply-meta { font-size: 0.78rem; color: var(--color-text-muted); margin: 0 0 0.3rem; }
</style>
