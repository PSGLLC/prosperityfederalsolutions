---
import PortalLayout from '../layouts/PortalLayout.astro';

const client = Astro.locals.client;
if (!client) return Astro.redirect('/login');

const db = Astro.locals.runtime.env.DB;

const [contracts, tickets, documents, unread, activity] = await Promise.all([
  db.prepare("SELECT COUNT(*) as c FROM contracts WHERE client_id = ? AND status = 'Active'").bind(client.id).first<{ c: number }>(),
  db.prepare("SELECT COUNT(*) as c FROM tickets WHERE client_id = ? AND status != 'Resolved'").bind(client.id).first<{ c: number }>(),
  db.prepare('SELECT COUNT(*) as c FROM documents WHERE client_id = ?').bind(client.id).first<{ c: number }>(),
  db.prepare('SELECT COUNT(*) as c FROM messages WHERE client_id = ? AND author_type = \'admin\' AND read_by_client = 0').bind(client.id).first<{ c: number }>(),
  db
    .prepare('SELECT event, created_at FROM activity_log WHERE client_id = ? ORDER BY created_at DESC LIMIT 8')
    .bind(client.id)
    .all<{ event: string; created_at: string }>(),
]);
---
<PortalLayout title="Dashboard" unreadCount={unread?.c ?? 0}>
  <h1>Welcome back, {client.fullName.split(' ')[0]}</h1>
  <p class="lede">Here's an overview of your account with Prosperity Federal Solutions.</p>

  <div class="grid grid-3 stats">
    <div class="card stat-card">
      <p class="stat-num">{contracts?.c ?? 0}</p>
      <p class="stat-label">Active Services</p>
    </div>
    <div class="card stat-card">
      <p class="stat-num">{tickets?.c ?? 0}</p>
      <p class="stat-label">Open Support Tickets</p>
    </div>
    <div class="card stat-card">
      <p class="stat-num">{documents?.c ?? 0}</p>
      <p class="stat-label">Documents on File</p>
    </div>
  </div>

  <div class="grid grid-2 dash-lower">
    <div class="card">
      <h2>Quick Actions</h2>
      <div class="quick-actions">
        <a href="/documents/" class="btn btn-outline">View Documents</a>
        <a href="/tickets/" class="btn btn-outline">Contact Support</a>
        <a href="/appointments/" class="btn btn-outline">Schedule Appointment</a>
        <a href="/messages/" class="btn btn-outline">Messages</a>
      </div>
    </div>
    <div class="card">
      <h2>Recent Activity</h2>
      {activity.results.length === 0 ? (
        <p class="muted">No recent activity yet.</p>
      ) : (
        <ul class="activity-list">
          {activity.results.map((a) => (
            <li><span class="activity-date">{a.created_at}</span> {a.event}</li>
          ))}
        </ul>
      )}
    </div>
  </div>
</PortalLayout>

<style>
  .lede { color: var(--color-text-muted); margin-bottom: 2rem; }
  .stats { margin-bottom: 1.5rem; }
  .stat-card { text-align: center; }
  .stat-num { font-family: var(--font-heading); font-size: 2.5rem; color: var(--color-purple); margin: 0; }
  :root[data-theme='dark'] .stat-num { color: var(--color-teal); }
  .stat-label { color: var(--color-text-muted); margin: 0.25rem 0 0; font-weight: 600; }
  .quick-actions { display: flex; flex-wrap: wrap; gap: 0.75rem; }
  .muted { color: var(--color-text-muted); }
  .activity-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.6rem; font-size: 0.9rem; }
  .activity-date { color: var(--color-text-muted); font-size: 0.78rem; display: block; }
</style>
