---
import AdminLayout from '../../../layouts/AdminLayout.astro';

const admin = Astro.locals.admin;
if (!admin) return Astro.redirect('/admin/login');

const db = Astro.locals.runtime.env.DB;
const contracts = await db
  .prepare(
    `SELECT ct.id, ct.title, ct.status, ct.start_date, ct.expected_completion, c.id as client_id, c.full_name
     FROM contracts ct JOIN clients c ON c.id = ct.client_id ORDER BY ct.created_at DESC`,
  )
  .all<{ id: string; title: string; status: string; start_date: string | null; expected_completion: string | null; client_id: string; full_name: string }>();
---
<AdminLayout title="Contracts">
  <h1>All Contracts</h1>
  <p class="muted">To add a contract or update status, open the client's profile.</p>
  <div class="card">
    {contracts.results.length === 0 ? <p class="muted">No contracts yet.</p> : (
      <table>
        <thead><tr><th>Client</th><th>Title</th><th>Status</th><th>Start</th><th>Expected Completion</th><th></th></tr></thead>
        <tbody>
          {contracts.results.map((c) => (
            <tr>
              <td>{c.full_name}</td>
              <td>{c.title}</td>
              <td><span class={`badge badge-${c.status.toLowerCase()}`}>{c.status}</span></td>
              <td>{c.start_date || '—'}</td>
              <td>{c.expected_completion || '—'}</td>
              <td><a href={`/admin/clients/${c.client_id}/`} class="btn btn-outline btn-sm">Manage</a></td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </div>
</AdminLayout>
<style>.muted { color: var(--color-text-muted); margin-bottom: 1rem; }</style>
