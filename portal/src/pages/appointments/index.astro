---
import PortalLayout from '../../layouts/PortalLayout.astro';

const client = Astro.locals.client;
if (!client) return Astro.redirect('/login');

const db = Astro.locals.runtime.env.DB;
const unread = await db.prepare("SELECT COUNT(*) as c FROM messages WHERE client_id = ? AND author_type = 'admin' AND read_by_client = 0").bind(client.id).first<{ c: number }>();

const BOOKING_URL = 'https://host.safemsngr.com/widget/booking/o0AlHrGuSvXTT92td7IS';
// No GHL API token with calendar-read scope is configured in this
// environment, so upcoming appointments cannot be pulled in — this page
// links/embeds the real booking widget only, rather than fabricating a
// synced appointments list.
---
<PortalLayout title="Appointments" unreadCount={unread?.c ?? 0}>
  <h1>Schedule an Appointment</h1>
  <p class="lede">Book a consultation directly on our calendar below.</p>

  <div class="card booking-card">
    <iframe
      src={BOOKING_URL}
      title="Schedule a consultation"
      loading="lazy"
      class="booking-frame"
    ></iframe>
    <p class="fallback">
      If the calendar above doesn't load, <a href={BOOKING_URL} target="_blank" rel="noopener noreferrer">open the booking page directly</a>.
    </p>
  </div>
</PortalLayout>

<style>
  .lede { color: var(--color-text-muted); margin-bottom: 1.5rem; }
  .booking-frame { width: 100%; min-height: 720px; border: none; border-radius: 10px; }
  .fallback { font-size: 0.85rem; color: var(--color-text-muted); margin-top: 0.75rem; }
</style>
