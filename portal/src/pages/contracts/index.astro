---
import PortalLayout from '../../layouts/PortalLayout.astro';

const client = Astro.locals.client;
if (!client) return Astro.redirect('/login');

const db = Astro.locals.runtime.env.DB;
const contracts = await db
  .prepare('SELECT id, title, status, start_date, expected_completion, notes FROM contracts WHERE client_id = ? ORDER BY created_at DESC')
  .bind(client.id)
  .all<{ id: string; title: string; status: string; start_date: string | null; expected_completion: string | null; notes: string | null }>();
const unread = await db.prepare("SELECT COUNT(*) as c FROM messages WHERE client_id = ? AND author_type = 'admin' AND read_by_client = 0").bind(client.id).first<{ c: number }>();

function badgeClass(status: string) {
  return `badge badge-${status.toLowerCase()}`;
}
---
<PortalLayout title="Contracts" unreadCount={unread?.c ?? 0}>
  <h1>Contract Tracker</h1>
  <p class="lede">A read-only view of your contracts with Prosperity Federal Solutions. Contact us with any questions.</p>

  {contracts.results.length === 0 ? (
    <div class="card"><p class="muted">No contracts on file yet.</p></div>
  ) : (
    <div class="grid grid-2">
      {contracts.results.map((c) => (
        <div class="card">
          <div class="contract-head">
            <h2>{c.title}</h2>
            <span class={badgeClass(c.status)}>{c.status}</span>
          </div>
          <p class="detail"><strong>Start date:</strong> {c.start_date || 'TBD'}</p>
          <p class="detail"><strong>Expected completion:</strong> {c.expected_completion || 'TBD'}</p>
          {c.notes && <p class="detail notes">{c.notes}</p>}
        </div>
      ))}
    </div>
  )}
</PortalLayout>

<style>
  .lede { color: var(--color-text-muted); margin-bottom: 1.5rem; }
  .muted { color: var(--color-text-muted); }
  .contract-head { display: flex; align-items: center; justify-content: space-between; gap: 0.75rem; }
  .detail { font-size: 0.9rem; margin: 0.4rem 0; }
  .notes { color: var(--color-text-muted); }
</style>
