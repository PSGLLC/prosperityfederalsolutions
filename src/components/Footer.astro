---
import { TAGLINE, NAV_LINKS, CONTACT, BOOKING_URL } from '../site.config';
const year = 2026;
---
<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-top">
      <div class="footer-brand">
        <div class="brand-text">
          <span class="brand-name">Prosperity Federal Solutions</span>
          <span class="brand-tagline">Building Stronger Futures</span>
        </div>
      </div>
      <nav class="footer-links">
        {NAV_LINKS.filter((l) => l.href !== '/').map((l) => (
          <a href={l.href}>{l.label}</a>
        ))}
      </nav>
      <a href={BOOKING_URL} target="_blank" rel="noopener noreferrer" class="btn btn-teal">Schedule Consultation</a>
    </div>

    <div class="compliance">
      <p class="copyright">&copy; {year} Prosperity Federal Solutions LLC | Phone {CONTACT.phone} | {TAGLINE}</p>
      <p class="legal-links"><a href="/privacy/">Privacy Policy</a> | <a href="/terms/">Terms of Use</a></p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-dark);
    color: #e7dcf4;
    padding: 3.5rem 0 2rem;
    margin-top: 3rem;
  }
  .footer-inner { display: flex; flex-direction: column; gap: 2rem; }
  .footer-top {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba(255,255,255,0.12);
  }
  .brand-text { display: flex; flex-direction: column; }
  .brand-name { font-family: var(--font-heading); font-size: 1.1rem; font-weight: 700; color: var(--color-purple); line-height: 1.2; }
  .brand-tagline { font-family: var(--font-body); font-size: 0.75rem; color: var(--color-teal); letter-spacing: 0.05em; }
  .footer-links { display: flex; flex-wrap: wrap; gap: 1rem 1.5rem; }
  .footer-links a { color: #d8c8ea; text-decoration: none; font-size: 0.9rem; }
  .footer-links a:hover { color: var(--color-teal); }
  .compliance p {
    font-size: 0.78rem;
    line-height: 1.6;
    color: #b6a4cb;
    max-width: 900px;
    margin: 0 0 0.5rem;
  }
  .copyright { color: #9e8bb6; }
  .legal-links { font-size: 0.78rem; }
  .legal-links a { color: #b6a4cb; text-decoration: none; }
  .legal-links a:hover { color: var(--color-teal); }
</style>
