---
import BaseLayout from '../layouts/BaseLayout.astro';
import { CONTACT, BOOKING_URL } from '../site.config';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Prosperity Federal Solutions LLC',
  url: 'https://prosperityfederalsolutions.com/contact/',
  telephone: '+1-919-307-5874',
  email: 'kayla@priceservicesgroup.com',
};
---
<BaseLayout
  title="Contact Prosperity Federal Solutions for a Consult"
  description="Get in touch with Prosperity Federal Solutions about procurement, supply, and fulfillment solutions for government and institutional clients."
  path="/contact"
  jsonLd={jsonLd}
>
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Contact</p>
      <h1>Let's Talk About Your Procurement Needs</h1>
      <p class="subhead">
        Ready to discuss your procurement needs? We'd love to hear from you.
      </p>
      <div class="contact-details">
        <a href={CONTACT.phoneHref} class="contact-item">{CONTACT.phone}</a>
        <a href={`mailto:${CONTACT.email}`} class="contact-item">{CONTACT.email}</a>
      </div>
      <p class="booking-note">
        Prefer to talk? <a href={BOOKING_URL} target="_blank" rel="noopener noreferrer">Schedule a consultation</a>.
        Have a quick question? Check our <a href="/faq/">FAQ</a>.
      </p>
      <p class="last-reviewed">Last reviewed: July 2026</p>
    </div>
  </section>

  <section>
    <div class="container contact-grid">
      <div class="card">
        <h2>Send Us a Message</h2>
        <form id="contact-lead-form" class="lead-form" novalidate>
          <div class="form-row">
            <label for="firstName">First Name <span aria-hidden="true">*</span></label>
            <input type="text" id="firstName" name="firstName" autocomplete="given-name" required />
          </div>
          <div class="form-row">
            <label for="lastName">Last Name <span aria-hidden="true">*</span></label>
            <input type="text" id="lastName" name="lastName" autocomplete="family-name" required />
          </div>
          <div class="form-row">
            <label for="email">Email <span aria-hidden="true">*</span></label>
            <input type="email" id="email" name="email" autocomplete="email" required />
          </div>
          <div class="form-row">
            <label for="phone">Phone <span class="optional">(optional)</span></label>
            <input type="tel" id="phone" name="phone" autocomplete="tel" />
          </div>
          <div class="form-row">
            <label for="agencyName">Agency/Organization Name <span class="optional">(optional)</span></label>
            <input type="text" id="agencyName" name="agencyName" autocomplete="organization" />
          </div>
          <div class="form-row">
            <label for="message">Project Description <span aria-hidden="true">*</span></label>
            <textarea id="message" name="message" rows="5" required></textarea>
          </div>
          <div class="form-row">
            <label for="hearAboutUs">How did you hear about us? <span class="optional">(optional)</span></label>
            <input type="text" id="hearAboutUs" name="hearAboutUs" />
          </div>
          <!-- Honeypot — hidden from real visitors -->
          <div class="hp-field" aria-hidden="true">
            <label for="website">Website</label>
            <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
          </div>

          <div class="form-row form-row-checkbox">
            <label class="checkbox-label" for="smsOptIn">
              <input type="checkbox" id="smsOptIn" name="smsOptIn" required />
              <span>I agree to receive text messages from Prosperity Federal Solutions LLC. Message and data rates may apply.</span>
            </label>
          </div>

          <button type="submit" class="btn btn-primary form-submit">Send Message</button>
          <p id="contact-form-error" class="form-error" role="alert" hidden></p>
        </form>

        <div id="contact-form-success" class="form-success" hidden>
          <p>Thanks for reaching out — we'll be in touch soon!</p>
        </div>

        <p class="compliance-note">
          By submitting this form you agree to be contacted by Prosperity Federal Solutions LLC.
          We respect your privacy and will never sell your information.
        </p>
      </div>

      <div class="card card-accent info-card">
        <h2>Reach Us Directly</h2>
        <p><strong>Phone:</strong> <a href={CONTACT.phoneHref}>{CONTACT.phone}</a></p>
        <p><strong>Email:</strong> <a href={`mailto:${CONTACT.email}`}>{CONTACT.email}</a></p>
        <p>
          <a href={BOOKING_URL} target="_blank" rel="noopener noreferrer" class="btn btn-teal book-btn">Schedule a Consultation</a>
        </p>
      </div>
    </div>
  </section>

  <script>
    const form = document.getElementById('contact-lead-form') as HTMLFormElement | null;
    const errorEl = document.getElementById('contact-form-error');
    const successEl = document.getElementById('contact-form-success');

    form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      if (errorEl) {
        errorEl.hidden = true;
        errorEl.textContent = '';
      }

      const formData = new FormData(form);
      const smsOptIn = formData.get('smsOptIn') === 'on';

      if (!smsOptIn) {
        if (errorEl) {
          errorEl.textContent = 'Please check the box to agree to receive text messages.';
          errorEl.hidden = false;
        }
        return;
      }

      const payload = {
        firstName: String(formData.get('firstName') ?? '').trim(),
        lastName: String(formData.get('lastName') ?? '').trim(),
        email: String(formData.get('email') ?? '').trim(),
        phone: String(formData.get('phone') ?? '').trim(),
        agencyName: String(formData.get('agencyName') ?? '').trim(),
        message: String(formData.get('message') ?? '').trim(),
        hearAboutUs: String(formData.get('hearAboutUs') ?? '').trim(),
        website: String(formData.get('website') ?? ''),
        smsOptIn: true,
        pagePath: window.location.pathname,
      };

      const submitBtn = form.querySelector<HTMLButtonElement>('.form-submit');
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = 'Sending…';
      }

      try {
        const res = await fetch('/api/contact-lead', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const data = await res.json().catch(() => ({ ok: false }));

        if (res.ok && data.ok) {
          form.hidden = true;
          if (successEl) successEl.hidden = false;
        } else {
          throw new Error(data.error || 'Something went wrong. Please try again.');
        }
      } catch (err) {
        if (errorEl) {
          errorEl.textContent = err instanceof Error ? err.message : 'Something went wrong. Please try again.';
          errorEl.hidden = false;
        }
      } finally {
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Send Message';
        }
      }
    });
  </script>
</BaseLayout>

<style>
  .page-hero { background: var(--color-lavender); padding: 4rem 0; }
  :root[data-theme="dark"] .page-hero { background: var(--color-bg-alt); }
  .subhead { color: var(--color-text-muted); font-size: 1.1rem; max-width: 640px; margin-bottom: 1.5rem; }
  .contact-details { display: flex; flex-wrap: wrap; gap: 1.5rem; }
  .contact-item {
    font-weight: 700;
    color: var(--color-purple);
    text-decoration: none;
    font-size: 1.05rem;
  }
  :root[data-theme="dark"] .contact-item { color: var(--color-teal); }
  .booking-note { margin-top: 1rem; }
  .last-reviewed { color: var(--color-text-muted); font-size: 0.78rem; margin-top: 0.75rem; }

  .contact-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 2rem;
    align-items: start;
  }
  @media (max-width: 800px) {
    .contact-grid { grid-template-columns: 1fr; }
  }

  .info-card p { margin-bottom: 0.75rem; }
  .book-btn { margin-top: 0.5rem; }

  .lead-form { display: flex; flex-direction: column; gap: 1rem; }
  .form-row { display: flex; flex-direction: column; gap: 0.35rem; text-align: left; }
  .form-row label { font-weight: 600; font-size: 0.9rem; color: var(--color-text); }
  .form-row .optional { font-weight: 400; color: var(--color-text-muted); font-size: 0.8rem; }
  .form-row input, .form-row textarea {
    font-family: var(--font-body);
    font-size: 1rem;
    padding: 0.7rem 0.9rem;
    border-radius: 10px;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-text);
    resize: vertical;
  }
  .form-row input:focus, .form-row textarea:focus {
    outline: none;
    border-color: var(--color-purple);
    box-shadow: 0 0 0 3px rgba(144, 89, 181, 0.18);
  }
  :root[data-theme="dark"] .form-row input:focus,
  :root[data-theme="dark"] .form-row textarea:focus {
    border-color: var(--color-teal);
    box-shadow: 0 0 0 3px rgba(81, 222, 204, 0.18);
  }
  .hp-field { position: absolute; left: -9999px; width: 1px; height: 1px; overflow: hidden; }
  .form-row-checkbox { flex-direction: row; }
  .checkbox-label {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    font-weight: 400;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    cursor: pointer;
  }
  .checkbox-label input[type='checkbox'] {
    flex-shrink: 0;
    width: 1.1rem;
    height: 1.1rem;
    margin-top: 0.15rem;
    accent-color: var(--color-purple);
  }
  .form-submit { width: 100%; text-align: center; margin-top: 0.25rem; }
  .form-submit:disabled { opacity: 0.7; cursor: not-allowed; transform: none; }
  .form-error { color: #b3261e; font-size: 0.9rem; margin: 0; }
  .form-success {
    background: var(--color-lavender);
    border-radius: var(--radius);
    padding: 1.5rem;
    text-align: center;
    font-weight: 600;
    color: var(--color-text);
  }
  :root[data-theme="dark"] .form-success { background: rgba(81, 222, 204, 0.12); }
  .compliance-note {
    color: var(--color-text-muted);
    font-size: 0.78rem;
    margin: 1.25rem 0 0;
    text-align: center;
  }
</style>
