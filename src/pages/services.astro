---
import BaseLayout from '../layouts/BaseLayout.astro';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'GovernmentService',
    name: 'Procurement & Supply Services',
    provider: {
      '@type': 'Organization',
      name: 'Prosperity Federal Solutions LLC',
    },
    serviceType: 'Procurement, Vendor Management, Logistics, Operational Supply',
    areaServed: 'US',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: 'Our Government Services | Prosperity Federal Solutions',
    url: 'https://prosperityfederalsolutions.com/services/',
    speakable: {
      '@type': 'SpeakableSpecification',
      cssSelector: ['h1', '.subhead'],
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'What procurement and supply services do you offer?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'We source and supply general goods and equipment to meet the operational needs of federal, state, and local agencies, managing the process from sourcing through delivery with an emphasis on reliability and accuracy.',
        },
      },
      {
        '@type': 'Question',
        name: 'How does vendor sourcing and coordination work?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'We build and maintain a network of qualified vendors to support client requirements, coordinating with them directly so agencies get consistent quality without managing multiple relationships themselves.',
        },
      },
      {
        '@type': 'Question',
        name: 'How is contract fulfillment and logistics handled?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Once a contract is awarded, we manage fulfillment and logistics to make sure goods and services are delivered on time and as specified, keeping clients informed throughout the process.',
        },
      },
      {
        '@type': 'Question',
        name: 'Do you support ongoing operational supply needs, not just one-time contracts?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Yes. Beyond one-time procurement, we support the ongoing operational supply needs of our clients, helping agencies and institutions keep the goods and materials they depend on flowing reliably.',
        },
      },
      {
        '@type': 'Question',
        name: 'Is Prosperity Federal Solutions registered in SAM.gov?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'SAM.gov registration is currently in progress, with certifications pending, as part of our ongoing steps to formalize federal contracting eligibility.',
        },
      },
    ],
  },
];

const capabilities = [
  {
    title: 'Procurement & Supply of General Goods',
    desc: "We source and supply general goods and equipment to meet the operational needs of federal, state, and local agencies. Our team manages the procurement process from sourcing through delivery, with an emphasis on reliability and accuracy at every step.",
  },
  {
    title: 'Vendor Sourcing & Coordination',
    desc: "Prosperity Federal Solutions builds and maintains a network of qualified vendors to support client requirements. We coordinate with vendors directly, so agencies get consistent quality without having to manage multiple relationships themselves.",
  },
  {
    title: 'Contract Fulfillment & Logistics',
    desc: "Once a contract is awarded, execution matters. We manage fulfillment and logistics to make sure goods and services are delivered on time and as specified, keeping clients informed throughout the process.",
  },
  {
    title: 'Operational Supply Solutions',
    desc: "Beyond one-time procurement, we support the ongoing operational supply needs of our clients — helping agencies and institutions keep the goods and materials they depend on flowing reliably.",
  },
  {
    title: 'Scalable Procurement Systems',
    desc: "As client needs grow, our procurement processes are designed to scale with them. We build systems that can handle increasing volume and complexity without sacrificing reliability or compliance.",
  },
];
---
<BaseLayout
  title="Our Government Services | Prosperity Federal Solutions"
  description="Procurement & supply of general goods, vendor network development, contract fulfillment, operational supply solutions, and scalable procurement systems."
  path="/services"
  jsonLd={jsonLd}
>
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Services</p>
      <h1>Procurement &amp; Supply Capabilities</h1>
      <p class="subhead">
        Prosperity Federal Solutions supports government and institutional clients with reliable
        procurement, vendor coordination, fulfillment, and supply solutions built to scale.
      </p>
      <p class="page-links">Questions? See our <a href="/faq/">FAQ</a> or <a href="/contact/">contact us</a>.</p>
    </div>
  </section>

  {capabilities.map((c, i) => (
    <section class:list={[i % 2 === 1 ? 'section-alt' : '']}>
      <div class="container service-block">
        <h2>{c.title}</h2>
        <p class="service-desc">{c.desc}</p>
        <a href="/contact/" class="btn btn-primary">Get in Touch</a>
      </div>
    </section>
  ))}

  <section>
    <div class="container">
      <p class="last-reviewed">Last reviewed: July 2026</p>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero { background: var(--color-lavender); padding: 4rem 0; }
  :root[data-theme="dark"] .page-hero { background: var(--color-bg-alt); }
  .subhead { color: var(--color-text-muted); font-size: 1.1rem; max-width: 680px; }
  .page-links { font-size: 0.9rem; margin-top: 0.75rem; }
  .service-block { max-width: 780px; }
  .service-desc { color: var(--color-text-muted); font-size: 1.05rem; margin-bottom: 1.5rem; }
  .last-reviewed { color: var(--color-text-muted); font-size: 0.78rem; }
</style>
